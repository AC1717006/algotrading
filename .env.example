# ─────────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────────
# DATABASE  (AWS RDS PostgreSQL)
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://algotrader:password@your-rds-endpoint.amazonaws.com:5432/algotrading

# ─────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_min_32_char_random_string_for_access_tokens
JWT_REFRESH_SECRET=replace_with_different_32_char_secret_for_refresh_tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────────
# UPSTOX API
# ─────────────────────────────────────────────────────────────────
UPSTOX_API_KEY=your_upstox_api_key
UPSTOX_API_SECRET=your_upstox_api_secret
UPSTOX_ACCESS_TOKEN=your_daily_access_token
UPSTOX_REDIRECT_URI=https://your-domain.com/api/broker/callback
UPSTOX_BASE_URL=https://api.upstox.com/v2

# ─────────────────────────────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ─────────────────────────────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-algotrading-bucket

# ─────────────────────────────────────────────────────────────────
# TRADING
# ─────────────────────────────────────────────────────────────────
PAPER_TRADING_INITIAL_BALANCE=1000000

# ─────────────────────────────────────────────────────────────────
# RISK MANAGEMENT
# ─────────────────────────────────────────────────────────────────
MAX_DAILY_LOSS_PERCENT=2
MAX_TRADES_PER_DAY=20
MAX_POSITION_SIZE_PERCENT=10
CIRCUIT_BREAKER_LOSS_PERCENT=5

# ─────────────────────────────────────────────────────────────────
# ADMIN SEED CREDENTIALS  (change after first login)
# ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@algotrader.com
ADMIN_PASSWORD=ChangeMe@123
